{
  "name": "lcs-carousel-pipeline",
  "version": "1.0.0",
  "description": "Automated carousel post generator for The London Choral Service",
  "type": "module",
  "scripts": {
    "start": "node telegram-bot.js",
    "pipeline": "node scripts/pipeline.js",
    "dry-run": "node scripts/pipeline.js --dry-run",
    "render-only": "node scripts/pipeline.js --render-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "node scripts/setup-wizard/server.js",
    "setup:cli": "node scripts/setup-env.js",
    "install-service": "node scripts/install-service.js",
    "service:status": "launchctl list | grep lcs",
    "service:logs": "tail -f logs/stdout.log",
    "service:stop": "launchctl stop com.lcs.carousel-bot",
    "service:start": "launchctl start com.lcs.carousel-bot"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^23.0.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
