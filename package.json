{
  "name": "lcs-carousel-pipeline",
  "version": "1.0.0",
  "description": "Automated carousel post generator for The London Choral Service",
  "type": "module",
  "scripts": {
    "start": "node scripts/pipeline.js",
    "dry-run": "node scripts/pipeline.js --dry-run",
    "render-only": "node scripts/pipeline.js --render-only",
    "dashboard": "node dashboard/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "form-data": "^4.0.0",
    "jose": "^6.2.1",
    "node-fetch": "^3.3.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^23.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
